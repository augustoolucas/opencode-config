{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@cortexkit/opencode-magic-context",
    "./node_modules/commandcode-go-opencode-provider/plugin.ts",
    ["./plugin-src/plan-post-approval.ts", { "plan_post_approval_handoff_agent": "orchestrator" }]
  ],
  "permission": {
    "websearch": "allow",
    "bash": {
      "*": "ask"
    },
    "edit": "ask"
  },
  "provider": {
    "commandcode": {
      "name": "Command Code",
      "env": [
        "COMMANDCODE_API_KEY"
      ]
    }
  },
  "default_agent": "orchestrator",
  "share": "manual",
  "autoupdate": true,
  "lsp": true,
  "compaction": {
    "auto": false,
    "prune": false
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  },
  "agent": {
    "orchestrator": {
      "temperature": 0.25
    },
    "planner": {
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.2
    },
    "builder": {
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.1
    },
    "reviewer": {
      "model": "opencode-go/deepseek-v4-pro",
      "temperature": 0.1
    }
  }
}