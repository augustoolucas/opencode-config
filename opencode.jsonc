{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@cortexkit/opencode-magic-context",
    "./node_modules/commandcode-go-opencode-provider/plugin.ts"
  ],
  "permission": {
    "websearch": "allow",
  },
  "provider": {
    "commandcode": {
      "name": "Command Code",
      "env": [
        "COMMANDCODE_API_KEY"
      ]
    }
  },
  "default_agent": "orchestrator",
  "share": "manual",
  "autoupdate": true,
  "lsp": true,
  "compaction": {
    "auto": false,
    "prune": false
  },
  "mcp": {
    "codegraph": {
      "type": "local",
      "command": [
        "codegraph",
        "serve",
        "--mcp"
      ],
      "enabled": true
    }
  }
}