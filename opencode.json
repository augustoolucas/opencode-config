{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@cortexkit/opencode-magic-context",
    "context-mode",
    "./node_modules/commandcode-go-opencode-provider/plugin.ts"
  ],
  "permission": {
    "websearch": "allow"
  },
  "provider": {
    "commandcode": {
      "npm": "commandcode-go-opencode-provider",
      "name": "Command Code",
      "env": ["COMMANDCODE_API_KEY"]
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": { "~/repos/**/.opencode/plans/**": "allow", "*": "deny" }
      },
      "temperature": 0.25
    }
  },
  "lsp": true,
  "compaction": {
    "auto": false,
    "prune": false
  }
}
